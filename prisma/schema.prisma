generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  topics      Topic[]
}

model Topic {
  id            String   @id @default(cuid())
  title         String
  description   String?
  source        String
  sourceUrl     String?
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  trendingScore Int      @default(0)
  fetchedAt     DateTime @default(now())
  prompts       Prompt[]

  @@index([categoryId])
  @@index([source])
  @@index([fetchedAt])
}

model Prompt {
  id            String   @id @default(cuid())
  topicId       String
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  aiVideoPrompt String   @db.Text
  videoScript   String   @db.Text
  style         String?
  duration      String?
  tags          String?
  generatedAt   DateTime @default(now())
  selected      Boolean  @default(false)

  @@index([topicId])
  @@index([generatedAt])
}

model CronLog {
  id       String   @id @default(cuid())
  taskType String
  status   String
  message  String?  @db.Text
  runAt    DateTime @default(now())

  @@index([runAt])
}
